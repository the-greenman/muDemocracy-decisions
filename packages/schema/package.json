{
  "name": "@repo/schema",
  "version": "0.0.0",
  "description": "Zod schemas - Single Source of Truth",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
