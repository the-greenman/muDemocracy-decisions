  },
  "dependencies": {
    "zod": "^3.22.0",
    "@hono/zod-openapi": "^0.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
