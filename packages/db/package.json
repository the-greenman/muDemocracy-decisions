{
  "name": "@repo/db",
  "version": "0.0.0",
  "description": "Drizzle ORM and database layer",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "require": "./dist/schema.cjs",
      "default": "./dist/schema.js"
    }
  },
  "scripts": {
    "build": "tsup --no-dts && tsc --project tsconfig.declarations.json",
    "dev": "tsup --watch --no-dts",
    "db:generate": "drizzle-kit generate:pg",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:push": "drizzle-kit push:pg",
    "db:studio": "drizzle-kit studio",
    "db:validate": "drizzle-kit check:pg",
    "db:seed": "tsx scripts/seed.ts",
    "test": "vitest run --minWorkers=1 --maxWorkers=1",
    "type-check": "tsc --project tsconfig.declarations.json"
  },
  "dependencies": {
    "@repo/schema": "workspace:*",
    "drizzle-orm": "0.29.5",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "dotenv-cli": "^7.4.4",
    "drizzle-kit": "0.20.18",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
