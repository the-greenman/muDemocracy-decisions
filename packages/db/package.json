{
  "name": "@repo/db",
  "version": "0.0.0",
  "description": "Drizzle ORM and database layer",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./schema": {
      "types": "./dist/schema.d.mts",
      "import": "./dist/schema.mjs",
      "require": "./dist/schema.js",
      "default": "./dist/schema.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --no-dts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:validate": "drizzle-kit check:pg",
    "db:seed": "tsx scripts/seed.ts",
    "test": "vitest run --minWorkers=1 --maxWorkers=1",
    "type-check": "tsc --build --emitDeclarationOnly"
  },
  "dependencies": {
    "@repo/schema": "workspace:*",
    "drizzle-orm": "^0.29.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "dotenv-cli": "^7.4.4",
    "drizzle-kit": "^0.20.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
