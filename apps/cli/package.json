{
  "name": "decision-logger",
  "version": "1.0.0",
  "description": "Decision Logger CLI",
  "main": "./dist/index.js",
  "type": "module",
  "bin": {
    "dlogger": "./dist/index.js",
    "decision-logger": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "cli": "dotenv -e ../../.env -- tsx src/index.ts",
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "start": "dotenv -e ../../.env -- node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "type-check": "tsc --project tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "dotenv-cli": "^7.4.4",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
