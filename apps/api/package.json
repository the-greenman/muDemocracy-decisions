{
  "name": "@repo/api",
  "version": "1.0.0",
  "description": "Hono REST API",
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "generate:openapi": "node scripts/export-openapi.mjs",
    "build:with-openapi": "tsup && npm run generate:openapi",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:api": "vitest run --config vitest.e2e.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "type-check": "tsc --project tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/zod-openapi": "^0.11.0",
    "@repo/core": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/schema": "workspace:*",
    "hono": "^4.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
